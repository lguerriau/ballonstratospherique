  </property>
  <property name="windowTitle">
   <string>Mission Control - Nacelle Alpha</string>
  </property>
  <property name="styleSheet">
   <string>
    /* Le fond : Espace profond */
    QWidget {
        background-color: #05080f;
        color: #00ffcc; /* Cyan Néon pour la télémétrie */
        font-family: 'Consolas', 'Courier New', monospace; /* Look console informatique */
    }

    /* Le conteneur principal */
    QTabWidget::pane {
        border: 1px solid #005577;
        background: #0b0f19;
    }

    /* Les onglets : Écrans de contrôle inactifs */
    QTabBar::tab {
        background: #05080f;
        color: #0088aa;
        padding: 8px 25px;
        border: 1px solid #005577;
        border-bottom: none;
        border-top-left-radius: 4px;
        border-top-right-radius: 4px;
        margin-right: 2px;
    }

    /* L'onglet actif : Écran allumé */
    QTabBar::tab:selected {
        background: #0b0f19;
        color: #00ffcc;
        border: 1px solid #00ffcc;
        border-bottom: none;
        font-weight: bold;
    }

    /* Les cadres de données (Température, etc.) : Interface HUD */
    QGroupBox {
        border: 1px solid #0088aa;
        border-radius: 4px;
        margin-top: 15px;
        background-color: rgba(11, 15, 25, 0.8);
    }
    QGroupBox::title {
        subcontrol-origin: margin;
        left: 10px;
        padding: 0 5px;
        color: #ffffff;
        font-weight: bold;
    }

    /* Les labels (Les valeurs elles-mêmes) */
    QLabel {
        color: #ffffff; /* Valeurs en blanc pour contraster avec le cyan */
    }

    /* Les boutons : Panneaux d'activation */
    QPushButton {
        background-color: #003344;
        color: #00ffcc;
        border: 1px solid #0088aa;
        border-radius: 3px;
        padding: 8px 15px;
        font-weight: bold;
        text-transform: uppercase;
    }
    QPushButton:hover {
        background-color: #005577;
        border: 1px solid #00ffcc;
        color: #ffffff;
    }

    /* Bouton d'action principale (Vidéo) : Surcharge propulseur */
    QPushButton#btn_generer_video {
        background-color: #4a0011;
        color: #ff3366;
        border: 1px solid #aa0033;
    }
    QPushButton#btn_generer_video:hover {
        background-color: #770022;
        color: #ffffff;
        border: 1px solid #ff3366;
    }

    /* Le tableau des requêtes : Journal de bord */
    QTableWidget {
        background-color: #020408;
        gridline-color: #004466;
        color: #aaddff;
        border: 1px solid #005577;
        selection-background-color: #005577;
        selection-color: #ffffff;
    }
    QHeaderView::section {
        background-color: #002233;
        color: #00ffcc;
        font-weight: bold;
        border: 1px solid #004466;
        padding: 4px;
    }
    
    /* Combobox (Menu déroulant des requêtes) */
    QComboBox {
        background-color: #003344;
        color: #00ffcc;
        border: 1px solid #0088aa;
        padding: 5px;
    }
   </string>
